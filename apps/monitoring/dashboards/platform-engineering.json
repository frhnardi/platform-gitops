{
  "title": "Platform Engineering",
  "uid": "platform-engineering",
  "tags": ["platform", "infra", "ops"],
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes",
      "gridPos": {"x": 0, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "count(kube_node_info)", "legendFormat": "Nodes", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ready Nodes",
      "gridPos": {"x": 3, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "legendFormat": "Ready", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Deployments",
      "gridPos": {"x": 6, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "count(kube_deployment_created)", "legendFormat": "Deploys", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pods",
      "gridPos": {"x": 9, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "count(kube_pod_info)", "legendFormat": "Pods", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Services",
      "gridPos": {"x": 12, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "count(kube_service_info)", "legendFormat": "Svcs", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Namespaces",
      "gridPos": {"x": 15, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "count(kube_namespace_created)", "legendFormat": "NS", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total Memory (GB)",
      "gridPos": {"x": 18, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "sum(kube_node_status_allocatable{resource=\"memory\"}) / 1073741824", "legendFormat": "GB", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}, "unit": "decgbytes", "decimals": 1}}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "K8s Events (Warning)",
      "gridPos": {"x": 21, "y": 0, "w": 3, "h": 3},
      "targets": [{"expr": "count(kube_event_created{type=\"Warning\"})", "legendFormat": "Warn", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 5}, {"color": "red", "value": 20}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "Node CPU Usage %",
      "gridPos": {"x": 0, "y": 3, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "sum by (kubernetes_io_hostname) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m])) / on(kubernetes_io_hostname) group_left kube_node_status_allocatable{resource=\"cpu\"} * 100",
          "legendFormat": "{{kubernetes_io_hostname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 60}, {"color": "red", "value": 85}]}}}
    },
    {
      "id": 11,
      "type": "gauge",
      "title": "Node Memory Usage %",
      "gridPos": {"x": 12, "y": 3, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "sum by (kubernetes_io_hostname) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"}) / on(kubernetes_io_hostname) group_left kube_node_status_allocatable{resource=\"memory\"} * 100",
          "legendFormat": "{{kubernetes_io_hostname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 20,
      "type": "bargauge",
      "title": "Pods per Namespace",
      "gridPos": {"x": 0, "y": 9, "w": 8, "h": 6},
      "targets": [{"expr": "count by (namespace) (kube_pod_info)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "CPU by Namespace",
      "gridPos": {"x": 8, "y": 9, "w": 8, "h": 6},
      "targets": [{"expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m]))", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "cores", "custom": {"fillOpacity": 15, "lineWidth": 2}}}
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Memory by Namespace (MB)",
      "gridPos": {"x": 16, "y": 9, "w": 8, "h": 6},
      "targets": [{"expr": "sum by (namespace) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"}) / 1048576", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Mbytes", "custom": {"fillOpacity": 15, "lineWidth": 2}}}
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "CPU per Node (cores)",
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 6},
      "targets": [{"expr": "sum by (kubernetes_io_hostname) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m]))", "legendFormat": "{{kubernetes_io_hostname}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "cores", "custom": {"fillOpacity": 10, "lineWidth": 2}}}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Memory Usage per Node (GB)",
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 6},
      "targets": [{"expr": "sum by (kubernetes_io_hostname) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"}) / 1073741824", "legendFormat": "{{kubernetes_io_hostname}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "decgbytes", "custom": {"fillOpacity": 10, "lineWidth": 2}}}
    },
    {
      "id": 40,
      "type": "stat",
      "title": "Total CPU (cores)",
      "gridPos": {"x": 0, "y": 21, "w": 4, "h": 3},
      "targets": [{"expr": "sum(kube_node_status_allocatable{resource=\"cpu\"})", "legendFormat": "cores", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 41,
      "type": "stat",
      "title": "Network RX (1h)",
      "gridPos": {"x": 4, "y": 21, "w": 4, "h": 3},
      "targets": [{"expr": "sum(increase(container_network_receive_bytes_total[1h])) / 1048576", "legendFormat": "MB", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Mbytes", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 42,
      "type": "stat",
      "title": "Network TX (1h)",
      "gridPos": {"x": 8, "y": 21, "w": 4, "h": 3},
      "targets": [{"expr": "sum(increase(container_network_transmit_bytes_total[1h])) / 1048576", "legendFormat": "MB", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Mbytes", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 43,
      "type": "stat",
      "title": "Ephemeral Storage (GB)",
      "gridPos": {"x": 12, "y": 21, "w": 4, "h": 3},
      "targets": [{"expr": "sum(kube_node_status_allocatable{resource=\"ephemeral_storage\"}) / 1073741824", "legendFormat": "GB", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "decgbytes", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 44,
      "type": "stat",
      "title": "Node Uptime (days)",
      "gridPos": {"x": 16, "y": 21, "w": 4, "h": 3},
      "targets": [{"expr": "max(time() - kube_node_created) / 86400", "legendFormat": "days", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 45,
      "type": "table",
      "title": "Kubernetes Events (Warning)",
      "gridPos": {"x": 20, "y": 21, "w": 4, "h": 3},
      "targets": [{"expr": "kube_event_created{type=\"Warning\"}", "legendFormat": "{{reason}}", "format": "table", "instant": true, "refId": "A"}]
    }
  ]
}
