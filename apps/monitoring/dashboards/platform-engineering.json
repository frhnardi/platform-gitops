{
  "title": "Platform Engineering",
  "uid": "platform-engineering",
  "panels": [
    {"title":"Cluster Nodes","type":"stat","gridPos":{"x":0,"y":0,"w":4,"h":3},"targets":[{"expr":"count(kube_node_info)","refId":"A"}]},
    {"title":"Running Pods","type":"stat","gridPos":{"x":4,"y":0,"w":4,"h":3},"targets":[{"expr":"count(kube_pod_status_phase{phase=\"Running\"})","refId":"A"}]},
    {"title":"Deployments Ready","type":"stat","gridPos":{"x":8,"y":0,"w":4,"h":3},"targets":[{"expr":"sum(kube_deployment_status_condition{condition=\"Available\",status=\"true\"})","refId":"A"}]},
    {"title":"Total Namespaces","type":"stat","gridPos":{"x":12,"y":0,"w":4,"h":3},"targets":[{"expr":"count(kube_namespace_created)","refId":"A"}]},
    {"title":"Pods per Namespace","type":"bargauge","gridPos":{"x":16,"y":0,"w":8,"h":3},"targets":[{"expr":"count(kube_pod_status_phase{phase=\"Running\"}) by (namespace)","refId":"A","legendFormat":"{{namespace}}"}]},
    {"title":"CPU Usage by Namespace","type":"timeseries","gridPos":{"x":0,"y":3,"w":12,"h":8},"targets":[{"expr":"sum(rate(container_cpu_usage_seconds_total{namespace!=\"\",container!=\"\"}[5m])) by (namespace)","refId":"A","legendFormat":"{{namespace}}"}]},
    {"title":"Memory Usage by Namespace (MB)","type":"timeseries","gridPos":{"x":12,"y":3,"w":12,"h":8},"targets":[{"expr":"sum(container_memory_working_set_bytes{namespace!=\"\",container!=\"\"}) by (namespace) / 1024 / 1024","refId":"A","legendFormat":"{{namespace}}"}]},
    {"title":"Container Restarts (1h)","type":"timeseries","gridPos":{"x":0,"y":11,"w":12,"h":6},"targets":[{"expr":"sum(increase(kube_pod_container_status_restarts_total[1h])) by (namespace)","refId":"A","legendFormat":"{{namespace}}"}]},
    {"title":"Pod Status Overview","type":"table","gridPos":{"x":12,"y":11,"w":12,"h":6},"targets":[{"expr":"count by (namespace,phase) (kube_pod_status_phase{phase!=\"Succeeded\"})","refId":"A","format":"table","instant":true}]}
  ],
  "schemaVersion": 39,
  "tags": ["platform","paved-road"],
  "timezone": "browser"
}
