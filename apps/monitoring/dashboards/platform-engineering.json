{
  "title": "Platform Engineering",
  "uid": "platform-engineering",
  "tags": ["platform", "infra", "ops"],
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "timepicker": {"refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"]},
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Platform Health Score",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 6},
      "targets": [{
        "expr": "clamp_max(100 * (sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"}) / count(kube_node_info) * 0.3 + count(kube_pod_status_phase{phase=\"Running\"}) / count(kube_pod_info) * 0.3 + sum(kube_deployment_status_condition{condition=\"Available\",status=\"true\"}) / count(kube_deployment_created) * 0.4), 100)",
        "refId": "A"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showThresholdLabels": true, "showThresholdMarkers": true},
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 70},
            {"color": "green", "value": 90}
          ]}
        }
      }
    },
    {
      "id": 2, "type": "stat", "title": "Nodes",
      "gridPos": {"x": 6, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "count(kube_node_info)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 3, "type": "stat", "title": "Ready Nodes",
      "gridPos": {"x": 8, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 4, "type": "stat", "title": "Deployments",
      "gridPos": {"x": 10, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "count(kube_deployment_created)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 5, "type": "stat", "title": "Pods",
      "gridPos": {"x": 12, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "count(kube_pod_info)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 6, "type": "stat", "title": "Running Pods",
      "gridPos": {"x": 14, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "count(kube_pod_status_phase{phase=\"Running\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}
    },
    {
      "id": 7, "type": "stat", "title": "Namespaces",
      "gridPos": {"x": 16, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "count(kube_namespace_created)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 8, "type": "stat", "title": "Services",
      "gridPos": {"x": 18, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "count(kube_service_info)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 9, "type": "stat", "title": "DaemonSets",
      "gridPos": {"x": 20, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "count(kube_daemonset_created)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 10, "type": "stat", "title": "K8s Events (Warn)",
      "gridPos": {"x": 22, "y": 0, "w": 2, "h": 2},
      "targets": [{"expr": "count(kube_event_created{type=\"Warning\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 5}, {"color": "red", "value": 20}]}}}
    },
    {
      "id": 11, "type": "stat", "title": "Pod Health Rate",
      "gridPos": {"x": 6, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "clamp_max(100 * count(kube_pod_status_phase{phase=\"Running\"}) / count(kube_pod_info), 100)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 80}, {"color": "green", "value": 95}]}}}
    },
    {
      "id": 12, "type": "stat", "title": "Deploy Ready Rate",
      "gridPos": {"x": 8, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "clamp_max(100 * sum(kube_deployment_status_condition{condition=\"Available\",status=\"true\"}) / count(kube_deployment_created), 100)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 80}, {"color": "green", "value": 95}]}}}
    },
    {
      "id": 13, "type": "stat", "title": "Total CPU (cores)",
      "gridPos": {"x": 10, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "sum(kube_node_status_allocatable{resource=\"cpu\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 14, "type": "stat", "title": "Total Memory (GB)",
      "gridPos": {"x": 12, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "sum(kube_node_status_allocatable{resource=\"memory\"}) / 1073741824", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "decgbytes", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 15, "type": "stat", "title": "Container Restarts (24h)",
      "gridPos": {"x": 14, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "sum(increase(kube_pod_container_status_restarts_total[24h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "id": 16, "type": "stat", "title": "Network RX (1h)",
      "gridPos": {"x": 16, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "sum(increase(container_network_receive_bytes_total[1h])) / 1048576", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Mbytes", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 17, "type": "stat", "title": "Network TX (1h)",
      "gridPos": {"x": 18, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "sum(increase(container_network_transmit_bytes_total[1h])) / 1048576", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Mbytes", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 18, "type": "stat", "title": "Uptime (days)",
      "gridPos": {"x": 20, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "max(time() - kube_node_created) / 86400", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 19, "type": "stat", "title": "Storage (GB)",
      "gridPos": {"x": 22, "y": 2, "w": 2, "h": 2},
      "targets": [{"expr": "sum(kube_node_status_allocatable{resource=\"ephemeral_storage\"}) / 1073741824", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "decgbytes", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 20, "type": "gauge", "title": "CPU Usage per Node (%)",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "targets": [{"expr": "sum by (kubernetes_io_hostname) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m])) / scalar(sum by (kubernetes_io_hostname) (kube_node_status_allocatable{resource=\"cpu\"})) * 100", "legendFormat": "{{kubernetes_io_hostname}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 60}, {"color": "red", "value": 85}]}}}
    },
    {
      "id": 21, "type": "gauge", "title": "Memory Usage per Node (%)",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
      "targets": [{"expr": "sum by (kubernetes_io_hostname) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"}) / scalar(sum by (kubernetes_io_hostname) (kube_node_status_allocatable{resource=\"memory\"})) * 100", "legendFormat": "{{kubernetes_io_hostname}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 30, "type": "bargauge", "title": "Pods per Namespace",
      "gridPos": {"x": 0, "y": 12, "w": 8, "h": 7},
      "targets": [{"expr": "count by (namespace) (kube_pod_info)", "legendFormat": "{{namespace}}", "refId": "A"}]
    },
    {
      "id": 31, "type": "timeseries", "title": "CPU Usage by Namespace (cores)",
      "gridPos": {"x": 8, "y": 12, "w": 8, "h": 7},
      "targets": [{"expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m]))", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "cores", "custom": {"fillOpacity": 15, "lineWidth": 2}}}
    },
    {
      "id": 32, "type": "timeseries", "title": "Memory by Namespace (MB)",
      "gridPos": {"x": 16, "y": 12, "w": 8, "h": 7},
      "targets": [{"expr": "sum by (namespace) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"}) / 1048576", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Mbytes", "custom": {"fillOpacity": 15, "lineWidth": 2}}}
    },
    {
      "id": 40, "type": "timeseries", "title": "Container Restarts (30m)",
      "gridPos": {"x": 0, "y": 19, "w": 12, "h": 7},
      "targets": [{"expr": "sum(increase(kube_pod_container_status_restarts_total[30m])) by (namespace)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 10, "lineWidth": 2}}}
    },
    {
      "id": 41, "type": "table", "title": "Pod Status Detail",
      "gridPos": {"x": 12, "y": 19, "w": 12, "h": 7},
      "targets": [{"expr": "count by (namespace, phase) (kube_pod_status_phase{phase!=\"Succeeded\"})", "format": "table", "instant": true, "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"renameByName": {"namespace": "Namespace", "phase": "Phase", "Value": "Count"}, "excludeByName": {"Time": true}}}]
    }
  ]
}
