      "id": 114,
      "type": "stat",
      "title": "\ud83d\udccb Deploy Ready %",
      "gridPos": {
        "x": 8,
        "y": 10,
        "w": 2,
        "h": 4
      },
      "targets": [
        {
          "expr": "clamp_max(100 * sum(kube_deployment_status_condition{condition=\"Available\",status=\"true\"}) / count(kube_deployment_created), 100)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "id": 115,
      "type": "stat",
      "title": "\u26a0\ufe0f Events (Warn)",
      "gridPos": {
        "x": 10,
        "y": 10,
        "w": 2,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase!=\"Running\"}) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        }
      }
    },
    {
      "id": 120,
      "type": "timeseries",
      "title": "\ud83d\udcc8 Health Score Trend (6h)",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "clamp_max(100 * (sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"}) / count(kube_node_info) * 0.30 + count(kube_pod_status_phase{phase=\"Running\"}) / count(kube_pod_info) * 0.30 + sum(kube_deployment_status_condition{condition=\"Available\",status=\"true\"}) / count(kube_deployment_created) * 0.30 + (1 - (sum(increase(kube_pod_container_status_restarts_total[1h])) / (count(kube_pod_container_status_restarts_total) + 1))) * 0.10), 100)",
          "legendFormat": "Health Score",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 3,
            "axisPlacement": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "\ud83e\udde9 What's Running Where?",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 201,
      "type": "timeseries",
      "title": "\ud83d\udcca Namespace Breakdown \u2014 Pods",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "count by (namespace) (kube_pod_info)",
          "legendFormat": "{{namespace}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 202,
      "type": "timeseries",
      "title": "\ud83d\udcbb CPU Usage by Namespace (cores)",
      "gridPos": {
        "x": 8,
        "y": 23,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m]))",
          "legendFormat": "{{namespace}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "custom": {
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 203,
      "type": "timeseries",
      "title": "\ud83e\udde0 Memory by Namespace (MB)",
      "gridPos": {
        "x": 16,
        "y": 23,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (namespace) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"}) / 1048576",
          "legendFormat": "{{namespace}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Mbytes",
          "custom": {
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "\u26a0\ufe0f What Needs Attention?",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 301,
      "type": "timeseries",
      "title": "\ud83d\udd04 Container Restarts (30m)",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total[30m])) by (namespace, pod)",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 302,
      "type": "timeseries",
      "title": "\ud83d\udd14 Warning Events Rate",
      "gridPos": {
        "x": 12,
        "y": 32,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total[5m]))",
          "legendFormat": "{{namespace}}/{{involved_object_name}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 303,
      "type": "table",
      "title": "\ud83d\udccb Pod Status Detail",
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "count by (namespace, phase) (kube_pod_status_phase{phase!=\"Succeeded\"})",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "namespace": "Namespace",
              "phase": "Phase",
              "Value": "Count"
            },
            "excludeByName": {
              "Time": true
            }
          }
        }
      ]
    },
    {
      "id": 304,
      "type": "table",
      "title": "\ud83d\uddc4\ufe0f Top Memory Consumers",
      "gridPos": {
        "x": 12,
        "y": 39,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "topk(10, sum by (pod, namespace) (container_memory_working_set_bytes{container!=\"\",pod!=\"\"}) / 1048576)",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "namespace": "Namespace",
              "pod": "Pod",
              "Value": "Memory (MB)"
            },
            "excludeByName": {
              "Time": true
            }
          }
        }
      ]
    }
  ]
}