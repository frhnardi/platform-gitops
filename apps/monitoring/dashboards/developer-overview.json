{
  "title": "Developer Overview",
  "uid": "developer-overview",
  "panels": [
    {"title":"Deployments by Namespace","type":"table","gridPos":{"x":0,"y":0,"w":12,"h":8},"targets":[{"expr":"kube_deployment_status_condition{condition=\"Available\",status=\"true\"}","refId":"A","format":"table","instant":true}]},
    {"title":"Pod Health","type":"bargauge","gridPos":{"x":12,"y":0,"w":12,"h":8},"targets":[{"expr":"count(kube_pod_status_phase{phase=\"Running\"}) by (namespace)","refId":"A","legendFormat":"Running"},{"expr":"count(kube_pod_status_phase{phase!=\"Running\",phase!=\"Succeeded\"}) by (namespace)","refId":"B","legendFormat":"Not Running"}]},
    {"title":"Container Restarts (1h)","type":"stat","gridPos":{"x":0,"y":8,"w":6,"h":4},"targets":[{"expr":"sum(increase(kube_pod_container_status_restarts_total[1h]))","refId":"A"}],"fieldConfig":{"defaults":{"thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":1},{"color":"red","value":5}]}}}},
    {"title":"Pods Pending/Failed","type":"stat","gridPos":{"x":6,"y":8,"w":6,"h":4},"targets":[{"expr":"count(kube_pod_status_phase{phase=~\"Pending|Failed|Unknown\"})","refId":"A"}],"fieldConfig":{"defaults":{"thresholds":{"steps":[{"color":"green","value":0},{"color":"red","value":1}]}}}}
