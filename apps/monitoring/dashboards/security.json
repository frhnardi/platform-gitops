{
  "title": "Security Dashboard",
  "uid": "security",
  "tags": ["security", "compliance", "kyverno"],
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "🎯 Active Policies",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 3},
      "targets": [{"expr": "count(count by (policy_name) (kyverno_policy_rule_info_total))", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "📏 Policy Rules",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 3},
      "targets": [{"expr": "count(kyverno_policy_rule_info_total)", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "🗂️ Protected Workloads",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 3},
      "targets": [{"expr": "count(kube_pod_info)", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "🔑 Secrets",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 3},
      "targets": [{"expr": "count(kube_secret_info)", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "📝 ConfigMaps",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 3},
      "targets": [{"expr": "count(kube_configmap_info)", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "🌐 Network Policies",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 3},
      "targets": [{"expr": "count(kube_networkpolicy_created)", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 1}, {"color": "green", "value": 5}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "⚠️ Non-Running Pods",
      "gridPos": {"x": 0, "y": 3, "w": 4, "h": 3},
      "targets": [{"expr": "count(kube_pod_status_phase{phase!=\"Running\"})", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 5}, {"color": "red", "value": 15}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 11,
      "type": "stat",
      "title": "🔄 Restarts (1h)",
      "gridPos": {"x": 4, "y": 3, "w": 4, "h": 3},
      "targets": [{"expr": "sum(increase(kube_pod_container_status_restarts_total[1h]))", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 3}, {"color": "red", "value": 10}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 12,
      "type": "stat",
      "title": "📦 Policy Changes (1h)",
      "gridPos": {"x": 8, "y": 3, "w": 4, "h": 3},
      "targets": [{"expr": "sum(increase(kyverno_policy_changes_total[1h]))", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 13,
      "type": "stat",
      "title": "🔁 Reconciles (1h)",
      "gridPos": {"x": 12, "y": 3, "w": 4, "h": 3},
      "targets": [{"expr": "sum(increase(kyverno_controller_reconcile_total[1h]))", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 14,
      "type": "stat",
      "title": "🧹 Pending Pods",
      "gridPos": {"x": 16, "y": 3, "w": 4, "h": 3},
      "targets": [{"expr": "count(kube_pod_status_phase{phase=\"Pending\"})", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 15,
      "type": "stat",
      "title": "💀 Failed Pods",
      "gridPos": {"x": 20, "y": 3, "w": 4, "h": 3},
      "targets": [{"expr": "count(kube_pod_status_phase{phase=\"Failed\"})", "legendFormat": "", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 3}]}, "unit": "short", "decimals": 0}}
    },
    {
      "id": 20,
      "type": "bargauge",
      "title": "📊 Pods by Namespace",
      "gridPos": {"x": 0, "y": 6, "w": 8, "h": 6},
      "targets": [{"expr": "count by (namespace) (kube_pod_info)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "🏷️ Secrets by Type",
      "gridPos": {"x": 8, "y": 6, "w": 8, "h": 6},
      "targets": [{"expr": "count by (type) (kube_secret_type)", "legendFormat": "{{type}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}}
    },
    {
      "id": 22,
      "type": "bargauge",
      "title": "📦 Secrets by Namespace",
      "gridPos": {"x": 16, "y": 6, "w": 8, "h": 6},
      "targets": [{"expr": "count by (namespace) (kube_secret_info)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]}}}
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "📈 Policy Changes Over Time",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum(rate(kyverno_policy_changes_total[5m]))", "legendFormat": "changes", "refId": "A"},
        {"expr": "sum(rate(kyverno_controller_reconcile_total[5m]))", "legendFormat": "reconciles", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"fillOpacity": 10, "lineWidth": 2}}}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "🔄 Pod Restarts by Namespace",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 6},
      "targets": [{"expr": "sum by (namespace) (rate(kube_pod_container_status_restarts_total[5m]))", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"fillOpacity": 10, "lineWidth": 2}}}
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "📋 Pod Status by Phase",
      "gridPos": {"x": 0, "y": 18, "w": 12, "h": 6},
      "targets": [{"expr": "count by (phase) (kube_pod_status_phase)", "legendFormat": "{{phase}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 15, "lineWidth": 2}}}
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "🌐 Network Policies by Namespace",
      "gridPos": {"x": 12, "y": 18, "w": 12, "h": 6},
      "targets": [{"expr": "count by (namespace) (kube_networkpolicy_created)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 15, "lineWidth": 2}}}
    },
    {
      "id": 40,
      "type": "table",
      "title": "📜 Active Policies & Rules",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 6},
      "targets": [{"expr": "kyverno_policy_rule_info_total", "format": "table", "instant": true, "refId": "A"}]
    },
    {
      "id": 41,
      "type": "table",
      "title": "⚠️ Non-Running Pods Detail",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 6},
      "targets": [{"expr": "kube_pod_status_phase{phase!=\"Running\"}", "format": "table", "instant": true, "refId": "A"}]
    }
  ]
}
