{
  "title": "Security Dashboard",
  "uid": "security",
  "tags": [
    "security",
    "kyverno",
    "compliance"
  ],
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Policy Evaluations (Pass)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "sum(kyverno_policy_results_total{result=\"pass\"})",
          "legendFormat": "Pass",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Policy Evaluations (Fail)",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "sum(kyverno_policy_results_total{result=\"fail\"})",
          "legendFormat": "Fail",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Policies",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(count by (policy_name) (kyverno_policy_rule_info_total))",
          "legendFormat": "Policies",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Rules",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kyverno_policy_rule_info_total)",
          "legendFormat": "Rules",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Admission Requests (Total)",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "sum(kyverno_admission_requests_total)",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Pods Protected",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kube_pod_info)",
          "legendFormat": "Pods",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Policy Evaluations (Pass/Fail/Skip/Warn Rate)",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(rate(kyverno_policy_results_total{result=\"pass\"}[5m]))",
          "legendFormat": "\u2705 Pass",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kyverno_policy_results_total{result=\"fail\"}[5m]))",
          "legendFormat": "\u274c Fail",
          "refId": "B"
        },
        {
          "expr": "sum(rate(kyverno_policy_results_total{result=\"skip\"}[5m]))",
          "legendFormat": "\u23ed\ufe0f Skip",
          "refId": "C"
        },
        {
          "expr": "sum(rate(kyverno_policy_results_total{result=\"warn\"}[5m]))",
          "legendFormat": "\u26a0\ufe0f Warn",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "rps"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "P99 Admission Review Latency",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kyverno_admission_review_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kyverno_admission_review_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kyverno_admission_review_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "s"
        }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Failing Policies by Name",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (policy_name) (rate(kyverno_policy_results_total{result=\"fail\"}[5m]))",
          "legendFormat": "{{policy_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 21,
      "type": "piechart",
      "title": "Policy Results Distribution",
      "gridPos": {
        "x": 8,
        "y": 9,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (result) (kyverno_policy_results_total)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Non-Running Pods",
      "gridPos": {
        "x": 16,
        "y": 9,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase!=\"Running\"})",
          "legendFormat": "Not Running",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 23,
      "type": "stat",
      "title": ":latest Tag",
      "gridPos": {
        "x": 20,
        "y": 9,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(container_spec_image{image=~\".*:latest\"})",
