    {
      "id": 10,
      "type": "timeseries",
      "title": "\ud83d\udd0d Policy Evaluation Rate (by Result)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum(rate(kyverno_policy_results_total{rule_result=\"pass\"}[5m]))",
          "legendFormat": "\u2705 Pass",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kyverno_policy_results_total{rule_result=\"fail\"}[5m]))",
          "legendFormat": "\u274c Fail",
          "refId": "B"
        },
        {
          "expr": "sum(rate(kyverno_policy_results_total{rule_result=\"skip\"}[5m]))",
          "legendFormat": "\u23ed\ufe0f Skip",
          "refId": "C"
        },
        {
          "expr": "sum(rate(kyverno_policy_results_total{rule_result=\"warn\"}[5m]))",
          "legendFormat": "\u26a0\ufe0f Warn",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 12,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "rps"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "\u2705 Pass"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "\u274c Fail"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF7383",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "\u23ed\ufe0f Skip"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8AB8FF",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "\u26a0\ufe0f Warn"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FFB357",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "last",
            "mean",
            "max"
          ]
        }
      }
    },
