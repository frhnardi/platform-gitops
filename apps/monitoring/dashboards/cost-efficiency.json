{
  "title": "\ud83d\udcb0 Cost & Efficiency",
  "uid": "cost-efficiency",
  "tags": [
    "cost",
    "finops",
    "efficiency",
    "narrative"
  ],
  "refresh": "1m",
  "editable": true,
  "graphTooltip": 1,
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m",
      "30m"
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\ud83d\udcb8 Cost at a Glance",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 100,
      "type": "stat",
      "title": "\ud83d\udda5\ufe0f Total Nodes",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 3,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kube_node_info)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "\ud83d\udc8e Regular Nodes",
      "gridPos": {
        "x": 3,
        "y": 1,
        "w": 3,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kube_node_info)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "\u26a1 Spot Nodes",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 3,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kube_node_info{label_kubernetes_azure_com_agentpool=~\"spot.*\"})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 103,
      "type": "stat",
      "title": "\ud83d\udce6 Total Pods",
      "gridPos": {
        "x": 9,
        "y": 1,
        "w": 3,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kube_pod_info)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 104,
      "type": "stat",
      "title": "\ud83d\udcbe Total CPU (cores)",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 3,
        "h": 3
      },
      "targets": [
        {
          "expr": "sum(kube_node_status_allocatable{resource=\"cpu\"})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "decimals": 1,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 105,
      "type": "stat",
      "title": "\ud83e\udde0 Total Memory (GB)",
      "gridPos": {
        "x": 15,
        "y": 1,
        "w": 3,
        "h": 3
      },
      "targets": [
        {
          "expr": "sum(kube_node_status_allocatable{resource=\"memory\"}) / 1073741824",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
