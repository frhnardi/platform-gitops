    {
      "id": 601,
      "type": "table",
      "title": "\ud83d\udfe2 Low-Utilization Pods \u2014 Can We Reduce Requests?",
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "avg by (pod, namespace) (rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[1h])) < 0.01",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "namespace": "Namespace",
              "pod": "Pod",
              "Value": "Avg CPU (cores)"
            },
            "excludeByName": {
              "Time": true
            }
          }
        }
      ]
