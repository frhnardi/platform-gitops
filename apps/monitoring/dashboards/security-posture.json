{
  "title": "\ud83d\udee1\ufe0f Security & Compliance Posture",
  "uid": "security-posture",
  "tags": [
    "security",
    "compliance",
    "narrative"
  ],
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m"
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\ud83c\udfaf Security Posture at a Glance",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 100,
      "type": "gauge",
      "title": "\ud83d\udee1\ufe0f Security Posture Score",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "clamp_max(100 * (count(kyverno_policy_rule_info_total) / (count(kyverno_policy_rule_info_total) + 0) * 0.40 + (1 - (count(kube_pod_status_phase{phase!=\"Running\"}) / (count(kube_pod_info) + 1))) * 0.25 + (count(kube_networkpolicy_created) / (count(kube_networkpolicy_created) + 5)) * 0.15 + (1 - sum(increase(kube_pod_container_status_restarts_total[1h])) / (sum(kube_pod_container_status_restarts_total) + 1)) * 0.20), 100)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "dark-red",
                "value": null
              },
              {
                "color": "red",
                "value": 30
              },
              {
                "color": "orange",
                "value": 55
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "\ud83c\udfc6 Compliance Level",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "targets": [
        {
          "expr": "clamp_max(100 * (count(kyverno_policy_rule_info_total) / (count(kyverno_policy_rule_info_total) + 0) * 0.40 + (1 - (count(kube_pod_status_phase{phase!=\"Running\"}) / (count(kube_pod_info) + 1))) * 0.25), 100)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "string",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "yellow",
                "value": 55
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          },
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 30,
                "result": {
                  "text": "\ud83d\udd34 Critical",
                  "color": "red"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 30,
                "to": 55,
                "result": {
                  "text": "\ud83d\udfe0 Low",
                  "color": "orange"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 55,
                "to": 85,
                "result": {
                  "text": "\ud83d\udfe1 Moderate",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 85,
                "to": 101,
                "result": {
                  "text": "\ud83d\udfe2 Good",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
