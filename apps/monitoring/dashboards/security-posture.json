{
  "title": "🛡️ Security & Compliance Posture",
  "uid": "security-posture",
  "tags": ["security", "compliance", "narrative"],
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "timepicker": {"refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"]},
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🎯 Security Posture at a Glance",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 100,
      "type": "gauge",
      "title": "🛡️ Security Posture Score",
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 8},
      "targets": [{
        "expr": "clamp_max(100 * (count(kyverno_policy_rule_info_total) / (count(kyverno_policy_rule_info_total) + 0) * 0.40 + (1 - (count(kube_pod_status_phase{phase!=\"Running\"}) / (count(kube_pod_info) + 1))) * 0.25 + (count(kube_networkpolicy_created) / (count(kube_networkpolicy_created) + 5)) * 0.15 + (1 - sum(increase(kube_pod_container_status_restarts_total[1h])) / (sum(kube_pod_container_status_restarts_total) + 1)) * 0.20), 100)",
        "refId": "A"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showThresholdLabels": true, "showThresholdMarkers": true},
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "dark-red", "value": null},
            {"color": "red", "value": 30},
            {"color": "orange", "value": 55},
            {"color": "yellow", "value": 75},
            {"color": "green", "value": 90}
          ]}
        }
      }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "🏆 Compliance Level",
      "gridPos": {"x": 6, "y": 1, "w": 3, "h": 4},
      "targets": [{
        "expr": "clamp_max(100 * (count(kyverno_policy_rule_info_total) / (count(kyverno_policy_rule_info_total) + 0) * 0.40 + (1 - (count(kube_pod_status_phase{phase!=\"Running\"}) / (count(kube_pod_info) + 1))) * 0.25), 100)",
        "refId": "A"
      }],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "fieldConfig": {
        "defaults": {
          "unit": "string", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 30},
            {"color": "yellow", "value": 55},
            {"color": "green", "value": 85}
          ]},
          "mappings": [
            {"type": "range", "options": {"from": 0, "to": 30, "result": {"text": "🔴 Critical", "color": "red"}}},
            {"type": "range", "options": {"from": 30, "to": 55, "result": {"text": "🟠 Low", "color": "orange"}}},
            {"type": "range", "options": {"from": 55, "to": 85, "result": {"text": "🟡 Moderate", "color": "yellow"}}},
            {"type": "range", "options": {"from": 85, "to": 101, "result": {"text": "🟢 Good", "color": "green"}}}
          ]
        }
      }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "📏 Active Policies",
      "gridPos": {"x": 9, "y": 1, "w": 3, "h": 4},
      "targets": [{"expr": "count(count by (policy_name) (kyverno_policy_rule_info_total))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 3}]}}}
    },
    {
      "id": 103,
      "type": "stat",
      "title": "📜 Policy Rules",
      "gridPos": {"x": 12, "y": 1, "w": 3, "h": 4},
      "targets": [{"expr": "count(kyverno_policy_rule_info_total)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 10}]}}}
    },
    {
      "id": 104,
      "type": "stat",
      "title": "🔑 Secrets Count",
      "gridPos": {"x": 15, "y": 1, "w": 3, "h": 4},
      "targets": [{"expr": "count(kube_secret_info)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 105,
      "type": "stat",
      "title": "🌐 Network Policies",
      "gridPos": {"x": 18, "y": 1, "w": 3, "h": 4},
      "targets": [{"expr": "count(kube_networkpolicy_created)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 1}, {"color": "green", "value": 5}]}}}
    },
    {
      "id": 106,
      "type": "stat",
      "title": "⚠️ Non-Compliant Pods",
      "gridPos": {"x": 21, "y": 1, "w": 3, "h": 4},
      "targets": [{"expr": "count(kube_pod_status_phase{phase!=\"Running\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "id": 110,
      "type": "stat",
      "title": "💀 Failed Pods",
      "gridPos": {"x": 6, "y": 5, "w": 3, "h": 3},
      "targets": [{"expr": "count(kube_pod_status_phase{phase=\"Failed\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 3}]}}}
    },
    {
      "id": 111,
      "type": "stat",
      "title": "🧹 Pending Pods",
      "gridPos": {"x": 9, "y": 5, "w": 3, "h": 3},
      "targets": [{"expr": "count(kube_pod_status_phase{phase=\"Pending\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}}
    },
    {
      "id": 112,
      "type": "stat",
      "title": "🔄 Restarts (1h)",
      "gridPos": {"x": 12, "y": 5, "w": 3, "h": 3},
      "targets": [{"expr": "sum(increase(kube_pod_container_status_restarts_total[1h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 3}, {"color": "red", "value": 10}]}}}
    },
    {
      "id": 113,
      "type": "stat",
      "title": "🔁 Kyverno Reconciles (1h)",
      "gridPos": {"x": 15, "y": 5, "w": 3, "h": 3},
      "targets": [{"expr": "sum(increase(kyverno_controller_reconcile_total[1h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 114,
      "type": "stat",
      "title": "📦 Policy Changes (1h)",
      "gridPos": {"x": 18, "y": 5, "w": 3, "h": 3},
      "targets": [{"expr": "sum(increase(kyverno_policy_changes_total[1h]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 200,
      "type": "row",
      "title": "🛡️ Policy Compliance Breakdown",
      "gridPos": {"x": 0, "y": 9, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 201,
      "type": "bargauge",
      "title": "📊 Pods by Namespace (Size = Attack Surface)",
      "gridPos": {"x": 0, "y": 10, "w": 8, "h": 8},
      "targets": [{"expr": "count by (namespace) (kube_pod_info)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "options": {"orientation": "horizontal"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}}
    },
    {
      "id": 202,
      "type": "bargauge",
      "title": "🔑 Secrets Distribution",
      "gridPos": {"x": 8, "y": 10, "w": 8, "h": 8},
      "targets": [{"expr": "count by (namespace) (kube_secret_info)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "options": {"orientation": "horizontal"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]}}}
    },
    {
      "id": 203,
      "type": "bargauge",
      "title": "🌐 Network Policy Coverage",
      "gridPos": {"x": 16, "y": 10, "w": 8, "h": 8},
      "targets": [{"expr": "count by (namespace) (kube_networkpolicy_created)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "options": {"orientation": "horizontal"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}
    },
    {
      "id": 300,
      "type": "row",
      "title": "📈 Security Events Over Time",
      "gridPos": {"x": 0, "y": 19, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 301,
      "type": "timeseries",
      "title": "🔄 Pod Restarts — Early Warning for Crashes/Attacks",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 6},
      "targets": [{"expr": "sum by (namespace) (rate(kube_pod_container_status_restarts_total[5m]))", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"fillOpacity": 15, "lineWidth": 2}}}
    },
    {
      "id": 302,
      "type": "timeseries",
      "title": "📊 Pod Status by Phase",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 6},
      "targets": [{"expr": "count by (phase) (kube_pod_status_phase)", "legendFormat": "{{phase}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}, "lineWidth": 1}}}
    },
    {
      "id": 303,
      "type": "timeseries",
      "title": "📝 Kyverno Policy Activity",
      "gridPos": {"x": 0, "y": 26, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum(rate(kyverno_policy_changes_total[5m]))", "legendFormat": "Changes", "refId": "A"},
        {"expr": "sum(rate(kyverno_controller_reconcile_total[5m]))", "legendFormat": "Reconciles", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"fillOpacity": 10, "lineWidth": 2}}}
    },
    {
      "id": 304,
      "type": "timeseries",
      "title": "🌐 Network Policies Over Time",
      "gridPos": {"x": 12, "y": 26, "w": 12, "h": 6},
      "targets": [{"expr": "count by (namespace) (kube_networkpolicy_created)", "legendFormat": "{{namespace}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 15, "lineWidth": 2}}}
    },
    {
      "id": 400,
      "type": "row",
      "title": "📜 Detailed Audit Tables",
      "gridPos": {"x": 0, "y": 33, "w": 24, "h": 1},
      "collapsed": false
    },
    {
      "id": 401,
      "type": "table",
      "title": "📜 Active Kyverno Policies",
      "gridPos": {"x": 0, "y": 34, "w": 12, "h": 7},
      "targets": [{"expr": "kyverno_policy_rule_info_total", "format": "table", "instant": true, "refId": "A"}]
    },
    {
      "id": 402,
      "type": "table",
      "title": "⚠️ Non-Running Pods (Investigate These!)",
      "gridPos": {"x": 12, "y": 34, "w": 12, "h": 7},
      "targets": [{"expr": "kube_pod_status_phase{phase!=\"Running\"}", "format": "table", "instant": true, "refId": "A"}]
    }
  ]
}
