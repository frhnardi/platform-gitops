{
  "title": "🔐 Supply Chain & Admission Enforcement",
  "uid": "supply-chain-enforcement",
  "tags": ["security", "supply-chain", "kyverno", "admission"],
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "timepicker": {"refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m"]},
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Admission Requests (24h)",
      "description": "Every create/update the cluster asked Kyverno to judge.",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(increase(kyverno_admission_requests_total[24h]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 2, "type": "stat", "title": "🛑 Blocked at Admission (24h)",
      "description": "Requests rejected by an enforce-mode policy. The platform doing its job.",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(increase(kyverno_policy_results_total{rule_result=~\"(?i)fail\", policy_validation_mode=~\"(?i)enforce\"}[24h]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}, {"color": "orange", "value": 1}]}}}
    },
    {
      "id": 3, "type": "stat", "title": "🔑 Signature Verifications (24h)",
      "description": "cosign keyless signature checks Kyverno ran on images (rule_type=imageVerify).",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(increase(kyverno_policy_results_total{rule_type=~\"(?i)imageverify\"}[24h]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}}
    },
    {
      "id": 4, "type": "stat", "title": "🚫 Unsigned Images Rejected (24h)",
      "description": "The thesis, quantified: images without a valid golden-path signature, refused entry.",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(increase(kyverno_policy_results_total{rule_type=~\"(?i)imageverify\", rule_result=~\"(?i)fail\"}[24h]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}}
    },
    {
      "id": 5, "type": "stat", "title": "Enforced Policies",
      "description": "Distinct policies currently running in enforce mode.",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "count(count by (policy_name) (kyverno_policy_rule_info_total{policy_validation_mode=~\"(?i)enforce\"}))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}
    },
    {
      "id": 6, "type": "stat", "title": "Admission Latency p95 (ms)",
      "description": "How much the enforcement layer costs each request at the 95th percentile.",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(kyverno_admission_review_duration_seconds_bucket[5m])) by (le)) * 1000", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "ms", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 200}, {"color": "red", "value": 1000}]}}}
    },
    {
      "id": 10, "type": "timeseries", "title": "Admission Results Over Time (pass / fail / warn)",
      "description": "Every policy evaluation, bucketed by outcome. Spikes in 'fail' are rejected deploys.",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 7},
      "targets": [{"expr": "sum by (rule_result) (increase(kyverno_policy_results_total[10m]))", "legendFormat": "{{rule_result}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 20, "lineWidth": 2, "stacking": {"mode": "normal"}}}}
    },
    {
      "id": 11, "type": "timeseries", "title": "🔑 Image Signature Verification (pass vs fail)",
      "description": "imageVerify outcomes only: a 'fail' line is an unsigned or wrongly-signed image turned away.",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 7},
      "targets": [{"expr": "sum by (rule_result) (increase(kyverno_policy_results_total{rule_type=~\"(?i)imageverify\"}[10m]))", "legendFormat": "{{rule_result}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 20, "lineWidth": 2, "pointSize": 6, "showPoints": "always"}}}
    },
    {
      "id": 20, "type": "bargauge", "title": "Blocks by Policy (24h)",
      "description": "Which enforce-mode policies are rejecting the most — the platform's teeth, ranked.",
      "gridPos": {"x": 0, "y": 11, "w": 8, "h": 8},
      "targets": [{"expr": "topk(10, sum by (policy_name) (increase(kyverno_policy_results_total{rule_result=~\"(?i)fail\", policy_validation_mode=~\"(?i)enforce\"}[24h])))", "legendFormat": "{{policy_name}}", "refId": "A"}],
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]}}}
    },
    {
      "id": 21, "type": "piechart", "title": "Policy Results by Rule Type",
      "description": "Where enforcement happens: validation vs mutation vs image signature checks.",
      "gridPos": {"x": 8, "y": 11, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (rule_type) (kyverno_policy_results_total)", "legendFormat": "{{rule_type}}", "refId": "A"}],
      "options": {"pieType": "donut", "legend": {"displayMode": "list", "placement": "right", "values": ["value"]}, "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 22, "type": "bargauge", "title": "Admission Requests by Operation (24h)",
      "description": "CREATE vs UPDATE vs DELETE traffic the enforcement layer handled.",
      "gridPos": {"x": 16, "y": 11, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (resource_request_operation) (increase(kyverno_admission_requests_total[24h]))", "legendFormat": "{{resource_request_operation}}", "refId": "A"}],
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 30, "type": "table", "title": "Enforcement Detail — denials & warnings",
      "description": "Which rule rejected what kind of resource. Empty is good; rows are the story to screenshot after the unsigned-image demo.",
      "gridPos": {"x": 0, "y": 19, "w": 24, "h": 8},
      "targets": [{"expr": "sum by (policy_name, rule_name, rule_type, resource_kind, rule_result) (kyverno_policy_results_total{rule_result=~\"(?i)fail|(?i)warn\"})", "format": "table", "instant": true, "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"renameByName": {"policy_name": "Policy", "rule_name": "Rule", "rule_type": "Type", "resource_kind": "Resource Kind", "rule_result": "Result", "Value": "Count"}, "excludeByName": {"Time": true}}}],
      "fieldConfig": {"defaults": {"custom": {"align": "left"}}}
    }
  ]
}
